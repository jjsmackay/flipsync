# Required — HuggingFace token for pyannote model download on first run
HF_TOKEN=hf_your_token_here

# Optional — host directory for model caches (demucs/pyannote/whisper).
# Defaults to /mnt/models/flipsync, the dedicated model-storage disk on the
# deploy host. Override for hosts without that mount (e.g. local dev).
# MODELS_ROOT=./data/models

# Optional — comma-separated extra hostnames the frontend's vite preview
# server will accept (e.g. behind a reverse proxy or custom domain).
# VITE_ALLOWED_HOSTS=your.deploy.hostname

# Optional — host-side ports for the orchestrator and frontend. Defaults
# shown. Container-internal ports are fixed (orchestrator 8000, frontend
# vite preview 3000) — these only change the host:container mapping. The UI
# reaches the orchestrator via the frontend's same-origin /api proxy, so
# ORCHESTRATOR_PORT only matters if you want to hit the API directly.
# ORCHESTRATOR_PORT=8000
# FRONTEND_PORT=3000

# Optional — comma-separated browser origins allowed to call the orchestrator
# API. Not needed for the UI (it calls same-origin /api). Only set this if
# something talks to the orchestrator's public port directly from a browser.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
